PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB URI — replace with your actual URI
# Example for Atlas: mongodb+srv://<user>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/portfolio_downloads

# OpenAI API Key — get yours from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model — gpt-4o-mini is fast and cheap, gpt-4o for higher quality
OPENAI_MODEL=gpt-4o-mini
